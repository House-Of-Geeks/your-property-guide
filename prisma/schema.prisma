generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Auth.js (NextAuth v5)
// ---------------------------------------------------------------------------
model User {
  id              String          @id @default(cuid())
  name            String?
  email           String          @unique
  emailVerified   DateTime?
  image           String?
  role            String          @default("agent") // "agent" | "agency_admin" | "admin"
  password        String?         // bcrypt hash — null for magic-link-only users
  accounts        Account[]
  sessions        Session[]
  savedProperties SavedProperty[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model SavedProperty {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, propertyId])
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime
  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Agency
// ---------------------------------------------------------------------------
model Agency {
  id              String   @id
  slug            String   @unique
  name            String
  logo            String
  description     String
  phone           String
  email           String
  website         String
  addressStreet   String
  addressSuburb   String
  addressState    String
  addressPostcode String
  addressFull     String
  suburbs         String[]
  primaryColor    String?
  youtubeVideoId  String?
  facebookUrl     String?
  instagramUrl    String?
  linkedinUrl     String?
  youtubeUrl      String?
  heroBg          String?
  // SEO metadata (editable in dashboard)
  metaTitle       String?
  metaDescription String?
  ogImage         String?

  agents     Agent[]
  properties Property[]
  packages   HouseAndLandPackage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Agent
// ---------------------------------------------------------------------------
model Agent {
  id              String   @id
  slug            String   @unique
  firstName       String
  lastName        String
  fullName        String
  title           String
  phone           String
  email           String   @unique
  bio             String
  image           String
  imageAlt        String?
  agencyId        String
  suburbs         String[]
  specialties     String[]
  yearsExperience Int
  propertiesSold  Int      @default(0)
  reviewCount     Int      @default(0)
  averageRating   Float    @default(0)
  isFeatured      Boolean  @default(false)
  // SEO metadata (editable in dashboard)
  metaTitle       String?
  metaDescription String?
  ogImage         String?

  agency        Agency                @relation(fields: [agencyId], references: [id])
  properties    Property[]            @relation("PropertyPrimaryAgent")
  coProperties  Property[]            @relation("PropertyCoAgent")
  packages      HouseAndLandPackage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agencyId])
  @@index([isFeatured])
  @@index([email])
}

// ---------------------------------------------------------------------------
// Property
// ---------------------------------------------------------------------------
model Property {
  id              String    @id
  slug            String    @unique
  // listingType: "buy" | "rent" | "sold" | "off-market" | "house-and-land"
  listingType     String
  // propertyType: "house" | "townhouse" | "apartment" | "unit" | "land" | "acreage" | "villa"
  propertyType    String
  // status: "active" | "under-contract" | "sold" | "off-market"
  status          String
  title           String
  addressStreet   String
  addressSuburb   String
  addressState    String    @default("QLD")
  addressPostcode String
  addressFull     String
  priceDisplay    String
  priceValue      Int?
  priceIsRange    Boolean   @default(false)
  priceMin        Int?
  priceMax        Int?
  priceRentPerWeek Int?
  bedrooms        Int
  bathrooms       Int
  carSpaces       Int
  landSize        Int?
  buildingSize    Int?
  description     String
  agentId         String
  coAgentId       String?
  agencyId        String
  suburbSlug      String
  inspectionTimes String[]
  auctionDate     DateTime?
  dateAdded       DateTime
  dateSold        DateTime?
  soldPrice       Int?
  isOffMarket     Boolean   @default(false)
  isFeatured      Boolean   @default(false)

  images   Property_Image[]
  agent           Agent           @relation("PropertyPrimaryAgent", fields: [agentId], references: [id])
  coAgent         Agent?          @relation("PropertyCoAgent", fields: [coAgentId], references: [id])
  agency          Agency          @relation(fields: [agencyId], references: [id])
  suburb          Suburb          @relation(fields: [suburbSlug], references: [slug])
  savedByUsers    SavedProperty[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Indexes for Australia-scale filtering and sorting
  @@index([listingType, status])
  @@index([suburbSlug])
  @@index([addressState])
  @@index([agentId])
  @@index([agencyId])
  @@index([priceValue])
  @@index([bedrooms])
  @@index([isFeatured])
  @@index([dateAdded])
}

model Property_Image {
  id         String   @id @default(cuid())
  url        String
  alt        String
  width      Int
  height     Int
  sortOrder  Int      @default(0)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

// ---------------------------------------------------------------------------
// Suburb
// ---------------------------------------------------------------------------
model Suburb {
  id               String   @id
  slug             String   @unique
  name             String
  postcode         String
  state            String
  region           String
  description      String
  heroImage        String
  // Stats
  medianHousePrice  Int
  medianUnitPrice   Int
  medianRentHouse   Int
  medianRentUnit    Int
  annualGrowthHouse Float
  annualGrowthUnit  Float
  daysOnMarket      Int
  salesCountHouse   Int     @default(0)
  population        Int
  medianAge         Int
  ownerOccupied     Float
  renterOccupied    Float
  householdsFamily     Float @default(0)
  householdsLonePerson Float @default(0)
  // Arrays
  amenities      String[]
  transportLinks String[]
  nearbySuburbs  String[]

  schools    School[]
  properties Property[]
  packages   HouseAndLandPackage[]

  // Centroid (from postcode CSV — used for proximity queries)
  lat Float?
  lng Float?

  // Data provenance
  statsSource    String    @default("seed") // "seed" | source ID e.g. "rental-vic"
  statsUpdatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([state])
  @@index([postcode])
  @@index([region])
}

model School {
  id       String @id @default(cuid())
  name     String
  // type: "primary" | "secondary" | "combined" | "special"
  type     String
  // sector: "government" | "catholic" | "independent"
  sector   String
  distance Float
  suburbId String
  suburb   Suburb @relation(fields: [suburbId], references: [id], onDelete: Cascade)
  // ACARA fields (populated by sync job)
  acaraId          String?   @unique
  lat              Float?
  lng              Float?
  icsea            Int?
  enrolment        Int?
  website          String?
  yearRange        String?   // e.g. "Prep-6", "7-12", "R-6"
  gender           String?   // "coed" | "girls" | "boys"
  updatedFromAcara DateTime?

  @@index([suburbId])
}

// ---------------------------------------------------------------------------
// Blog
// ---------------------------------------------------------------------------
model BlogPost {
  id          String    @id
  slug        String    @unique
  title       String
  excerpt     String
  content     String
  coverImage  String
  authorName  String
  authorImage String
  category    String
  tags        String[]
  publishedAt DateTime
  updatedAt   DateTime?
  readingTime Int

  createdAt DateTime @default(now())

  @@index([category])
  @@index([publishedAt])
}

// ---------------------------------------------------------------------------
// House & Land
// ---------------------------------------------------------------------------
model HouseAndLandPackage {
  id             String   @id
  slug           String   @unique
  title          String
  builder        String
  estate         String
  suburb         String
  suburbSlug     String
  priceDisplay   String
  priceValue     Int
  bedrooms       Int
  bathrooms      Int
  carSpaces      Int
  landSize       Int
  buildingSize   Int
  description    String
  floorPlanImage String?
  agentId        String
  agencyId       String
  inclusions     String[]
  isNew          Boolean  @default(false)
  dateAdded      DateTime

  images    HouseAndLand_Image[]
  agent     Agent  @relation(fields: [agentId], references: [id])
  agency    Agency @relation(fields: [agencyId], references: [id])
  suburbRef Suburb @relation(fields: [suburbSlug], references: [slug])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([suburbSlug])
  @@index([priceValue])
  @@index([builder])
  @@index([agentId])
}

model HouseAndLand_Image {
  id        String              @id @default(cuid())
  url       String
  alt       String
  sortOrder Int                 @default(0)
  packageId String
  package   HouseAndLandPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId])
}

// ---------------------------------------------------------------------------
// Data Sync Registry
// ---------------------------------------------------------------------------
model DataSource {
  id            String    @id       // e.g. "rental-vic", "crime-nsw", "acara-schools"
  label         String
  category      String              // "schools" | "rental" | "crime"
  schedule      String              // "annual" | "quarterly" | "monthly"
  sourceUrl     String
  lastFetchedAt DateTime?
  dataAsOf      DateTime?
  recordCount   Int?
  status        String    @default("idle") // "idle" | "running" | "ok" | "error"
  errorMsg      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Suburb Rental Stats (time series — one row per suburb per period per source)
// ---------------------------------------------------------------------------
model SuburbRentalStat {
  id              String   @id @default(cuid())
  suburbSlug      String?            // null until suburb exists in DB
  suburbName      String
  postcode        String
  state           String
  period          String             // e.g. "2024-Q3"
  periodDate      DateTime
  medianRentHouse Int?
  medianRentUnit  Int?
  medianRent3Bed  Int?
  medianRent2Bed  Int?
  medianRent1Bed  Int?
  bondLodgements  Int?
  source          String             // DataSource.id

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([suburbName, postcode, state, period])
  @@index([suburbSlug])
  @@index([state, period])
  @@index([postcode])
}

// ---------------------------------------------------------------------------
// Suburb Crime Stats (time series — one row per suburb per year per source)
// ---------------------------------------------------------------------------
model SuburbCrimeStat {
  id               String   @id @default(cuid())
  suburbSlug       String?
  suburbName       String
  postcode         String?
  lga              String?
  state            String
  period           String             // e.g. "2024"
  periodDate       DateTime
  totalOffences    Int
  offenceBreakdown Json     @default("{}")
  source           String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([suburbName, state, period, source])
  @@index([suburbSlug])
  @@index([state, period])
  @@index([lga])
}
